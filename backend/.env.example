# =========================================================
# CipherCube backend — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA subas tu `.env` a git (ya está en .gitignore).
# =========================================================

# ---- Servidor ----
NODE_ENV=development
PORT=4000
# Origen(es) del frontend permitidos por CORS (separa con comas).
# En producción pon tu dominio real: https://ciphercube.app
CORS_ORIGINS=http://localhost:8643,http://localhost:5500,http://127.0.0.1:8643

# URL pública del frontend (para redirigir tras el pago).
FRONTEND_URL=http://localhost:8643
# URL pública de ESTE backend (para webhooks y retornos de pago).
# En producción: https://api.ciphercube.app
PUBLIC_BACKEND_URL=http://localhost:4000

# ---- Base de datos PostgreSQL ----
# Opción A: cadena de conexión completa
DATABASE_URL=postgres://ciphercube:changeme@localhost:5432/ciphercube
# Opción B (si no usas DATABASE_URL): partes sueltas
PGHOST=localhost
PGPORT=5432
PGUSER=ciphercube
PGPASSWORD=changeme
PGDATABASE=ciphercube
# Pon true si tu Postgres exige SSL (muchos proveedores gestionados sí).
PGSSL=false

# ---- JWT / seguridad ----
# Genera secretos largos y aleatorios:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_REFRESH_SECRET=cambia_esto_por_OTRO_secreto_largo_y_aleatorio
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL_DAYS=30

# ---- Stripe ----
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Dashboard → Developers → Webhooks → (endpoint) → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Precios creados en Stripe (Products → Pricing). Uno por plan de pago.
STRIPE_PRICE_PLUS=price_xxx
STRIPE_PRICE_BOVEDA=price_xxx

# ---- PayPal ----
# developer.paypal.com → Apps & Credentials
PAYPAL_CLIENT_ID=xxx
PAYPAL_CLIENT_SECRET=xxx
# 'sandbox' para pruebas, 'live' en producción
PAYPAL_ENV=sandbox

# ---- MercadoPago ----
# mercadopago → Tus integraciones → Credenciales
MERCADOPAGO_ACCESS_TOKEN=xxx

# ---- Precios (en la moneda de cada proveedor) ----
# Se usan para PayPal/MercadoPago (Stripe usa sus price IDs de arriba).
PRICE_PLUS_USD=4.99
PRICE_BOVEDA_USD=9.99
PRICE_PLUS_MXN=99
PRICE_BOVEDA_MXN=199
